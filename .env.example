# =============================================================================
# Environment Variables Template
# Copy this file to .env and fill in your real values
# NEVER commit .env to version control
# =============================================================================

# --- PostgreSQL Database ---
# Primary DSN used by SQLAlchemy + asyncpg (override or derive from parts below)
POSTGRES_DSN=postgresql+asyncpg://trading_user:your_password@localhost:5432/trading_bot

# Individual parts (used by alembic / manual connections)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_bot
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=your_password

# --- MetaTrader 5 ---
MT5_LOGIN=123456
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_broker_server_name   # e.g. ICMarkets-Demo
# Absolute path to terminal64.exe — used by scripts/start_trading_bot.bat
# to launch MT5 automatically at Windows logon.
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# --- MetaTrader 5 Account Slots (for dashboard switching) ---
# Configure multiple MT5 accounts for switching from the dashboard.
# Each slot needs three env vars: MT5_SLOT_<NAME>_LOGIN, _PASSWORD, _SERVER.
# You can also register new slots from the dashboard UI (Settings > Add Account).
#
# MT5_SLOT_DEMO_LOGIN=123456
# MT5_SLOT_DEMO_PASSWORD=your_password
# MT5_SLOT_DEMO_SERVER=ICMarkets-Demo
#
# MT5_SLOT_LIVE_LOGIN=789012
# MT5_SLOT_LIVE_PASSWORD=your_password
# MT5_SLOT_LIVE_SERVER=ICMarkets-Live

# --- FRED API (Federal Reserve Economic Data) ---
# Free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# --- NewsAPI ---
# Free key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key

# --- CoinGecko (on-chain / crypto data) ---
# Free tier requires no key; Pro key optional for higher rate limits
# COINGECKO_API_KEY=your_coingecko_pro_key

# --- CFTC COT Data (Gold positioning) ---
# No API key needed — data fetched directly from CFTC website
# (previously used Nasdaq Data Link which required a paid key)

# --- Stooq (daily sovereign bond yields: UK/AU/NZ/JP/DE/US, 2Y + 10Y) ---
# Free key (captcha-gated) at: https://stooq.com/q/d/?s=10yuky.b&get_apikey
# When unset, src/data_pipeline/market/stooq_data.py returns empty/zero
# defaults (degrades gracefully, does not block bot startup).
# STOOQ_API_KEY=your_stooq_api_key

# --- Telegram Alerts (optional) ---
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message @userinfobot to get your numeric chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Email Alerts (optional, Gmail SMTP) ---
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords → generate an App Password
# 3. Paste the 16-char app password below (no spaces)
ALERT_EMAIL_FROM=your_email@gmail.com
ALERT_EMAIL_TO=recipient@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password
# Optional: override SMTP server (defaults to Gmail)
# ALERT_SMTP_HOST=smtp.gmail.com
# ALERT_SMTP_PORT=587
# Email scope (Telegram is always unaffected by these):
#   EMAIL_WEEKLY_ONLY=1  — strict. Only the Sunday 23:55 UTC weekly
#                          summary reaches email. Daily summary, trades,
#                          system events, breakers: Telegram-only.
#   EMAIL_DIGEST_ONLY=1  — looser. Daily + weekly summaries on email;
#                          everything else Telegram-only.
# If both set, WEEKLY_ONLY wins. Leave both unset for current behavior
# (every alert to every enabled channel).
# EMAIL_WEEKLY_ONLY=1

# --- Dashboard Auth ---
# Username you'll type at the login screen. Free-choose, any short string.
# If unset, defaults to "admin".
DASHBOARD_USERNAME=admin
# Generate with: python -c "import bcrypt; pw=input('Password: ').encode(); print(bcrypt.hashpw(pw, bcrypt.gensalt()).decode())"
DASHBOARD_PW_HASH=your_bcrypt_hash
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_JWT_SECRET=your_jwt_secret
# Bind host for the dashboard API. Default 127.0.0.1 (local only, safest).
# Set to 0.0.0.0 to expose on your LAN so you can hit the dashboard from
# your phone at http://<your-pc-ip>:8787. Only do this on trusted Wi-Fi.
# DASHBOARD_BIND_HOST=0.0.0.0
