*.keep

# Local smoke-test artifacts (Playwright MCP)
.playwright-mcp/
smoke-*.png

# Phase A bake-off verdict smoke outputs — regenerable by re-running
# scripts/bakeoff_verdict.py against the operator's chosen window.
docs/2a_pivot_results.md
data/logs/bakeoff/
data/logs/bakeoff_verdict/

# Model rollback backups + experiment subdirs (Phase 2BQ1, Q2, pre-prodtest,
# pre-expansion-retrain, threshold-test, etc). Convention: any dir under
# data/models/ that starts with `_` is ephemeral/experimental — keep on disk
# as recovery anchors but never commit (large binaries).
data/models/_*/

# Sprint 3 + canonical_v3 backtest artifacts (regenerable via
# scripts/backtest.py + scripts/portfolio_simulator.py from canonical recipe).
data/logs/sprint_3/canonical_v3/
data/logs/sprint_3/joint_sweep/
data/logs/sprint_3/baseline_path_d_optionA/

# Saturday LSTM retrain log (regenerable from train_deep_learning.py).
data/logs/saturday_lstm_retrain.log

# Convention: scripts/_<name>.py = ephemeral one-off diagnostic / A-B harness.
# Already-tracked underscore-prefixed scripts (e.g. _send_weekly_sample.py,
# _assert_prod_idle.py) keep being tracked since git only honors .gitignore
# for new files; only fresh `_<name>.py` scripts are auto-ignored.
scripts/_*.py
!scripts/_assert_prod_idle.py
!scripts/_feature_store_common.py
!scripts/_mt5_safety.py
!scripts/_phase2b_meta_opt2_clean_oos.py
!scripts/_phase2bq15_gbm_parity_vs_lstm_ab.py
!scripts/_phase2bq1_gbm_thin_vs_rich_ab.py
!scripts/_phase2bq1_shap_attribution.py
!scripts/_seed_mlflow_for_bench.py
!scripts/_send_weekly_sample.py
.superpowers/
