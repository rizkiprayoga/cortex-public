data/state/
# MLflow file-based tracking backend (T-8)
data/mlflow/
# A-8 training-distribution snapshots (regenerated each retrain)
data/models/*.training_dist.json

# Saved model weights (large binary files)
data/models/*.pkl
data/models/*.pt
data/models/*.pth
data/models/*.joblib
# Optuna SQLite study DBs (Phase A bake-off, regenerable)
data/models/*.db

# Model snapshots (rollback archives — regenerable, not committed)
data/model_snapshots/

# Backtest output artifacts
data/backtest_results/

# Walk-forward experiment results
data/walk_forward_results.json

# Jupyter notebooks — checkpoints
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

